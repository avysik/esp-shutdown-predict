    "method": "Expert archetypes constrained by mex.xlsx p05-p95-style field ranges and by steady-state scenario-design rules."
  },
  "global_guidance": {
    "fast_window_default": {
      "duration": "2h",
      "points": 9,
      "time_step": "15min",
      "use_for": [
        "inflow_deterioration",
        "wellhead_backpressure_growth",
        "voltage_sag"
      ]
    },
    "slow_window_default": {
      "duration": "4h",
      "points": 9,
      "time_step": "30min",
      "use_for": [
        "watercut_growth",
        "viscosity_growth"
      ]
    },
    "notes": [
      "Pump frequency is not a primary fleet archetype axis. Treat it as operator action in a second-stage generator.",
      "Select esp_id by nearest nominal rate/head/power match, not randomly.",
      "Use Latin hypercube sampling inside each archetype range, not globally over the whole fleet."
    ]
  },
